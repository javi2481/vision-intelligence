# Copiar a .env y ajustar. Todas las URLs usan nombres de servicio Docker.

# --- Puertos publicados en el host ---
ADAPTER_PORT=8000
PADDLEX_PORT=8080
JETLINKS_PORT=8848
RULES_SINK_PORT=8850
PADDLEX_OCR_PORT=8081
PADDLEX_OBJECTS_PORT=8082
PADDLEX_FACES_PORT=8083
PADDLEX_PEDESTRIANS_PORT=8084
PADDLEX_SCENE_PORT=8085

# --- URLs internas (red epp-network) ---
ADAPTER_INGEST_URL=http://adapter:8000/ingest
PADDLEX_URL=http://paddlex:8080
PADDLEX_PREDICT_PATH=/vehicle-attribute-recognition
PADDLEX_OCR_URL=http://paddlex-ocr:8081
PADDLEX_OBJECTS_URL=http://paddlex-objects:8082
PADDLEX_FACES_URL=http://paddlex-faces:8083
PADDLEX_PEDESTRIANS_URL=http://paddlex-pedestrians:8084
PADDLEX_SCENE_URL=http://paddlex-scene:8085

# --- Adaptador (consolidación de tracks) ---
TRACK_TTL_SECONDS=10
MAX_DETECTIONS_PER_TRACK=60
EVENTS_BUFFER_SIZE=500
CORS_ORIGINS=*
LOG_LEVEL=INFO
# development = permite JETLINKS_API_KEY=demo
# production  = exige claves fuertes (!= demo) en adapter y rules-sink
VI_ENV=development

# JetLinks (vacío = MVP local solo loguea en /webhook/rules)
JETLINKS_WEBHOOK_URL=
JETLINKS_API_KEY=demo

# --- rules-sink (perfil "rules") ---
# Sink FastAPI headless que decide sobre PerceptionEvents (alternativa
# reproducible a la UI SQL de jetlinks). Para activarlo:
#   1) docker compose --profile rules up --build
#   2) Setear JETLINKS_WEBHOOK_URL=http://rules-sink:8850/webhook/events
#      (el adaptador reenvía ahí en vez de solo loguear)
#   3) JETLINKS_API_KEY debe ser IGUAL a RULES_SINK_API_KEY
#   4) En VI_ENV=production ambas claves deben ser != "demo"
RULES_SINK_API_KEY=demo
RULES_SINK_MAX_ALERTS=100
# URL interna (red epp-network) que el adaptador usa para relayar
# GET /rules/health y GET /rules/alerts hacia rules-sink (read-only).
RULES_SINK_URL=http://rules-sink:8850

# --- Fotos locales (auto-select) + preview overlay EN ---
# MEDIA_DIR/images <- ./imagenes_muestra (JPGs en la raíz; no recursivo / DETRAC).
MEDIA_DIR=/media
# Cada cuántos segundos el bridge consulta GET /media/current para hot-swap.
MEDIA_POLL_INTERVAL=1.0
# Cada cuántos segundos el adapter escanea la carpeta (auto-select más nuevo).
MEDIA_WATCH_INTERVAL=1.0
ADAPTER_MEDIA_CURRENT_URL=http://adapter:8000/media/current
ADAPTER_PREVIEW_FRAME_URL=http://adapter:8000/preview/frame

# --- Bridge (foto-only) ---
# BRIDGE_FPS solo aplica a DEMO_MODE (ritmo de detecciones sintéticas).
# Preview = overlay OpenCV con labels EN (no result.image de PaddleX).
BRIDGE_FPS=1
JPEG_QUALITY=70
# CPU saturada: probar 640. Scene/seg: 960 suele bastar.
BRIDGE_MAX_WIDTH=960
DEMO_MODE=0
HTTP_TIMEOUT=30
PREVIEW_MJPEG_INTERVAL=0.05
PREVIEW_IMAGE_HEARTBEAT_SECONDS=5.0

# AVISO: no levantar profile "demo" (bridge-demo) junto al bridge real —
# mezcla detecciones sintéticas (ABC123) en el mismo /events.

# --- OCR de patente (perfil default, servicio paddlex-ocr) ---
# ENABLE_PLATE_OCR=false por default: apaga OCR en caliente sin afectar el
# flujo attr T1. Caída/timeout de paddlex-ocr => plate=None, sin degradar
# el bridge globalmente (_notify_degraded queda reservado al pipeline attr).
ENABLE_PLATE_OCR=false
OCR_MIN_SCORE=0.7
OCR_EVERY_N_FRAMES=5
OCR_TOPK=3
OCR_HTTP_TIMEOUT=5

# --- Capacidades extended (profile: docker compose --profile extended up --build) ---
# Levantan paddlex-faces :8083, paddlex-pedestrians :8084, paddlex-scene :8085.
# Flags default false: el bridge no llama si el servicio no está arriba.
ENABLE_FACE_DETECTION=false
ENABLE_PEDESTRIAN_ATTRS=false
ENABLE_SCENE_SEG=false
# cityscapes | lane (4 clases PP-Vehicle) | bdd_marks (incl. crosswalk)
SCENE_LABEL_MODE=cityscapes
# Carriles: SCENE_PIPELINE_CONFIG=/opt/paddlex/pipelines/scene_lane.yaml + SCENE_LABEL_MODE=lane
# Cruces+líneas BDD: SCENE_PIPELINE_CONFIG=/opt/paddlex/pipelines/scene_bdd_marks.yaml + SCENE_LABEL_MODE=bdd_marks
SCENE_PIPELINE_CONFIG=semantic_segmentation
CROSSWALK_MIN_RATIO=0.01

# --- Alto fit (profile extended) ---
ENABLE_POSE=false
PADDLEX_POSE_URL=http://paddlex-pose:8086
ENABLE_SCENE_OCR=false
# Reusa paddlex-ocr :8081 por default (mismo servicio que patentes)
SCENE_OCR_MIN_SCORE=0.5
SCENE_OCR_MAX_LINES=20
ENABLE_FACE_ID=false
PADDLEX_FACE_ID_URL=http://paddlex-face-id:8087
# Obligatorio si ENABLE_FACE_ID=true: identity en eventos es HMAC, nunca plaintext.
IDENTITY_HASH_SALT=
ENABLE_SIGNS=false
PADDLEX_SIGNS_URL=http://paddlex-signs:8088

# --- Medio fit (profile experimental) — requiere GATE documentado en detection/*/README ---
ENABLE_SCENE_CLS=false
ENABLE_INSTANCE_SEG=false
ENABLE_SMALL_OBJECTS=false
ENABLE_ANOMALY=false
ENABLE_OPEN_VOCAB=false

# Config del pipeline PaddleX que sirve paddlex-ocr (VI_PIPELINE). Default:
# PP-OCRv5 mobile (det+rec), pineado por incompatibilidad de PP-OCRv6 (default
# de paddlex 3.7.2) con el motor de inferencia de PADDLE_BASE_IMAGE (3.0.0).
# Cambiar solo si se actualiza PADDLE_BASE_IMAGE a una version que soporte
# PP-OCRv6, o para probar otro pipeline/config propio.
OCR_PIPELINE_CONFIG=/opt/paddlex/pipelines/ocr_v5_mobile.yaml
# Fuente en repo: detection/plates/pipeline.yaml (copiado al build de infra/Dockerfile.paddlex)

# --- PaddleX imagen base ---
# CPU (default):
PADDLE_BASE_IMAGE=paddlepaddle/paddle:3.0.0
# GPU (usar con: docker compose --profile gpu up --build):
PADDLE_GPU_BASE_IMAGE=paddlepaddle/paddle:3.0.0-gpu-cuda11.8-cudnn8.9-trt8.6
# HPIP (opcional, tras benchmark ≥~1.5×): VI_USE_HPIP=1
# Requiere plugin HPI en la imagen. Default off. Ver infra/README.
# Medir: PYTHONPATH=. python3 scripts/benchmark_paddlex.py --image <jpg> --rounds 5
VI_USE_HPIP=0
