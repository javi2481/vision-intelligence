{
  "type": "page",
  "title": "Vision Intelligence",
  "name": "vision-dashboard",
  "className": "vi-page",
  "toolbar": [
    {
      "type": "tpl",
      "tpl": "<span class=\"vi-badge\">Detección en foto</span>"
    }
  ],
  "body": [
    {
      "type": "panel",
      "title": "Foto analizada",
      "className": "vi-panel-main",
      "body": [
        {
          "type": "tpl",
          "className": "vi-preview text-center m-b",
          "tpl": "<img src=\"/preview.mjpg\" alt=\"Preview con detecciones\" />"
        },
        {
          "type": "service",
          "name": "mediaCurrentService",
          "id": "mediaCurrentService",
          "className": "m-b-sm",
          "api": {
            "method": "get",
            "url": "/media/current",
            "adaptor": "return { status:0, data:{ name:payload&&payload.name, type: (payload&&payload.type)||'—', generation:payload&&payload.generation } };"
          },
          "interval": 2500,
          "silentPolling": true,
          "body": {
            "type": "tpl",
            "className": "vi-status",
            "tpl": "<span class=\"vi-status-label\">${name ? \"Activa\" : \"Listo\"}</span> <strong>${name|default:\"Vision Intelligence\"}</strong> <span class=\"vi-muted\">${name ? (\"· gen \" + (generation || 0)) : \"· subí una foto para analizar\"}</span>"
          }
        },
        {
          "type": "grid",
          "columns": [
            {
              "md": 8,
              "body": {
                "type": "form",
                "name": "mediaUploadForm",
                "wrapWithPanel": false,
                "mode": "inline",
                "body": [
                  {
                    "type": "input-file",
                    "name": "file",
                    "label": false,
                    "accept": ".jpg,.jpeg,.png,.bmp,image/jpeg,image/png,image/bmp",
                    "receiver": "/media/upload",
                    "useChunk": false,
                    "autoUpload": true,
                    "multiple": false,
                    "drag": false,
                    "btnLabel": "Subir foto",
                    "btnClassName": "cxd-Button--primary",
                    "className": "vi-upload",
                    "description": false,
                    "onEvent": {
                      "success": {
                        "actions": [
                          {
                            "actionType": "reload",
                            "componentId": "detailService"
                          },
                          {
                            "actionType": "reload",
                            "componentId": "mediaCurrentService"
                          }
                        ]
                      }
                    }
                  }
                ]
              }
            },
            {
              "md": 4,
              "body": {
                "type": "button",
                "label": "Limpiar foto",
                "level": "default",
                "size": "sm",
                "block": true,
                "actionType": "ajax",
                "api": {
                  "method": "post",
                  "url": "/media/clear",
                  "adaptor": "return { status: (payload && payload.ok) ? 0 : 1, msg: (payload && payload.ok) ? 'Listo — Vision Intelligence' : 'No se pudo limpiar', data: payload };"
                },
                "reload": "mediaCurrentService,detailService"
              }
            }
          ]
        },
        {
          "type": "tpl",
          "className": "vi-hint m-t-sm",
          "tpl": "También podés copiar JPGs a <code>imagenes_muestra/</code> — se analiza la más nueva."
        }
      ]
    },
    {
      "type": "service",
      "name": "detailService",
      "id": "detailService",
      "className": "vi-detail",
      "api": {
        "method": "get",
        "url": "/events?limit=100",
        "adaptor": "var TYPE={vehicle:'Vehículo',car:'Auto',sedan:'Sedán',suv:'SUV',van:'Furgoneta',truck:'Camión',bus:'Colectivo',mpv:'Monovolumen',pickup:'Pickup',hatchback:'Hatchback',unknown:'Desconocido',person:'Persona',person_pose:'Pose',bicycle:'Bicicleta',motorcycle:'Motocicleta',dog:'Perro',cat:'Gato',backpack:'Mochila',handbag:'Bolso',umbrella:'Paraguas',suitcase:'Maleta','cell phone':'Celular',bottle:'Botella',chair:'Silla',bench:'Banco','traffic light':'Semáforo','stop sign':'Señal de stop',face:'Rostro',street:'Calle',highway:'Autopista',parking:'Estacionamiento',rural:'Rural',text:'Texto',sign:'Señal'}; var ENTITY={vehicle:'Vehículo',object:'Objeto',face:'Rostro',face_id:'Identidad',scene:'Escena',pose:'Pose',text:'Texto',sign:'Señal',scene_cls:'Clase escena',instance:'Instancia',small_object:'Obj. pequeño',anomaly:'Anomalía',open_vocab:'Open-vocab'}; var COLOR={red:'Rojo',blue:'Azul',green:'Verde',yellow:'Amarillo',white:'Blanco',black:'Negro',brown:'Marrón',silver:'Plateado',grey:'Gris',gray:'Gris',orange:'Naranja',purple:'Violeta',gold:'Dorado',golden:'Dorado'}; var events=(payload&&payload.events)||[]; var counts={}; var rows=events.map(function(e,i){ var et=e.entity_type||'vehicle'; var p=e.payload||{}; var rawT=p.vehicle_type||p.class_name||p.scene_type||p.identity||p.text||'unknown'; var rawC=p.color||null; var tipo=TYPE[rawT]||rawT; var entidad=ENTITY[et]||et; var color=rawC?(COLOR[rawC]||rawC):'—'; var extra='—'; if(et==='scene'&&p.scene){ var sc=p.scene; var bits=[]; if(sc.type) bits.push(sc.type); if(sc.crosswalk&&sc.crosswalk.present) bits.push('cruce'); if(sc.lanes&&sc.lanes.present) bits.push('carriles'); extra=bits.join(' · ')||'—'; } else if(p.person){ var pr=p.person; extra=[pr.gender,pr.age_group,pr.upper_color].filter(Boolean).join(' · ')||'—'; } else if(p.text){ extra=String(p.text).slice(0,40); } else if(p.keypoints){ extra='kp:'+p.keypoints.length; } else if(p.identity){ extra=String(p.identity); } counts[entidad]=(counts[entidad]||0)+1; var conf=e.confidence||0; return { n:i+1, entidad:entidad, tipo:tipo, color:color, extra:extra, conf:Math.round(conf*100), conf_label:(conf*100).toFixed(0)+'%', conf_level: conf>0.85?'alta':(conf>0.6?'media':'baja') }; }); var keys=Object.keys(counts); var pieData=keys.map(function(k){ return { name:k, value:counts[k] }; }); return { status:0, data:{ count:rows.length, degraded:!!(payload&&payload.degraded), empty:rows.length===0, rows:rows, pieData:pieData, chartConfig:{ color:['#0b6bcb','#e85d04','#2a9d8f','#9b5de5','#ef476f','#118ab2','#ffb703'], title:{ text:'Entidades en esta foto', left:'center', top:8, textStyle:{ fontSize:15, fontWeight:600, color:'#1a1f24' } }, tooltip:{ trigger:'item', formatter:'{b}: {c} ({d}%)' }, legend:{ bottom:4, type:'scroll' }, series:[{ type:'pie', radius:['40%','66%'], center:['50%','52%'], avoidLabelOverlap:true, itemStyle:{ borderRadius:8, borderColor:'#fff', borderWidth:2 }, label:{ formatter:'{b}\\n{d}%', fontSize:11 }, data:pieData }] } } };"
      },
      "interval": 4000,
      "silentPolling": true,
      "showErrorMsg": false,
      "body": [
        {
          "type": "panel",
          "title": "Detalle de la detección",
          "className": "vi-panel-detail",
          "body": [
            {
              "type": "tpl",
              "visibleOn": "${empty}",
              "className": "vi-empty",
              "tpl": "<div class=\"vi-empty-card\"><strong>Sin detecciones todavía</strong><p>Subí una foto o esperá un momento a que termine el análisis.</p></div>"
            },
            {
              "type": "grid",
              "visibleOn": "${!empty}",
              "columns": [
                {
                  "md": 4,
                  "body": {
                    "type": "tpl",
                    "className": "vi-stat-card",
                    "tpl": "<div class=\"vi-stat\"><div class=\"vi-stat-value\">${count}</div><div class=\"vi-stat-label\">Detectados</div></div>"
                  }
                },
                {
                  "md": 4,
                  "body": {
                    "type": "tpl",
                    "className": "vi-stat-card",
                    "tpl": "<div class=\"vi-stat\"><div class=\"vi-stat-value vi-stat-ok\">${degraded ? \"Atención\" : \"OK\"}</div><div class=\"vi-stat-label\">Motor de visión</div></div>"
                  }
                },
                {
                  "md": 4,
                  "body": {
                    "type": "tpl",
                    "className": "vi-stat-card",
                    "tpl": "<div class=\"vi-stat\"><div class=\"vi-stat-value\">${pieData.length|default:0}</div><div class=\"vi-stat-label\">Tipos distintos</div></div>"
                  }
                }
              ]
            },
            {
              "type": "grid",
              "visibleOn": "${!empty}",
              "className": "m-t",
              "columns": [
                {
                  "md": 5,
                  "body": {
                    "type": "chart",
                    "name": "typePie",
                    "height": 300,
                    "replaceChartOption": true,
                    "config": "${chartConfig}"
                  }
                },
                {
                  "md": 7,
                  "body": {
                    "type": "table",
                    "className": "vi-table",
                    "source": "${rows}",
                    "columnsTogglable": false,
                    "footable": false,
                    "searchable": true,
                    "columns": [
                      {
                        "name": "n",
                        "label": "#",
                        "width": 48
                      },
                      {
                        "name": "entidad",
                        "label": "Entidad",
                        "type": "tpl",
                        "tpl": "<span class=\"vi-pill vi-pill-type\">${entidad}</span>",
                        "searchable": {
                          "type": "select",
                          "name": "entidad",
                          "label": "Filtrar entidad",
                          "clearable": true,
                          "searchable": true,
                          "options": [
                            {
                              "label": "Vehículo",
                              "value": "Vehículo"
                            },
                            {
                              "label": "Objeto",
                              "value": "Objeto"
                            },
                            {
                              "label": "Rostro",
                              "value": "Rostro"
                            },
                            {
                              "label": "Identidad",
                              "value": "Identidad"
                            },
                            {
                              "label": "Escena",
                              "value": "Escena"
                            },
                            {
                              "label": "Pose",
                              "value": "Pose"
                            },
                            {
                              "label": "Texto",
                              "value": "Texto"
                            },
                            {
                              "label": "Señal",
                              "value": "Señal"
                            },
                            {
                              "label": "Persona",
                              "value": "Persona"
                            },
                            {
                              "label": "Clase escena",
                              "value": "Clase escena"
                            },
                            {
                              "label": "Instancia",
                              "value": "Instancia"
                            },
                            {
                              "label": "Obj. pequeño",
                              "value": "Obj. pequeño"
                            },
                            {
                              "label": "Anomalía",
                              "value": "Anomalía"
                            },
                            {
                              "label": "Open-vocab",
                              "value": "Open-vocab"
                            }
                          ]
                        }
                      },
                      {
                        "name": "tipo",
                        "label": "Tipo",
                        "type": "tpl",
                        "tpl": "<span class=\"vi-pill vi-pill-type\">${tipo}</span>"
                      },
                      {
                        "name": "color",
                        "label": "Color",
                        "type": "tpl",
                        "tpl": "<span class=\"vi-pill vi-pill-color\">${color}</span>"
                      },
                      {
                        "name": "extra",
                        "label": "Detalle",
                        "type": "tpl",
                        "tpl": "<span class=\"vi-muted\">${extra}</span>"
                      },
                      {
                        "name": "conf_label",
                        "label": "Confianza",
                        "type": "tpl",
                        "tpl": "<span class=\"vi-conf vi-conf-${conf_level}\">${conf_label}</span>"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
